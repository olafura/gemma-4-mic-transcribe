 #
 set -eu
 
+function resolve_tool() {
+    local -r env_var="$1"
+    local -r default_tool="$2"
+    local -r configured_tool="${!env_var:-}"
+
+    if [[ -n "${configured_tool}" ]]; then
+        echo "${configured_tool}"
+    else
+        command -v "${default_tool}" 2>/dev/null || echo "${default_tool}"
+    fi
+}
+
 LIBS=
 LIB_DIRS=
 RPATHS=
